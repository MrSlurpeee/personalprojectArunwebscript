{
  "compilerOptions": {
    "target": "ES2017",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": ["./*"]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts",
    "**/*.mts",
    "app/app/aruns-personal-page.js",
    "app/arunpersonalproj/page.tsx",
    "app/layout.jsx",
    "page.tsx",
    "app/layout.jsx",
    "app/home/index.js",
    "page.tsx",
    "app/component/DogApi.js",
    "app/about/page.jsx",
    "app/layout.jsx"
, "app/hobbies/page.jsx"  ],
  "exclude": ["node_modules"]
}
